# i-Finance Reporting runner — environment (COPY to env.ps1; env.ps1 is git-ignored).
# Reuses the otbi-atd DB env-var names so a shared worker VM needs no duplication;
# RPT_DB_* override them when set. SECRETS live here only — never in DCT_RPT_CONFIG.

# --- Database (thin mode + wallet) ---------------------------------------------
$env:ATD_DB_USER     = 'PROD'                       # or RPT_DB_USER
$env:ATD_DB_PASSWORD = '<db-password>'              # or RPT_DB_PASSWORD  (SECRET)
$env:ATD_DB_DSN      = 'gd5_low'                    # tnsnames alias (or RPT_DB_DSN)
$env:TNS_ADMIN       = 'C:\claude\DCT-task-management\DCT-Task-Management\myDoc'  # wallet dir
# $env:ATD_WALLET_PASSWORD = '<wallet-pwd>'         # only for a password-protected wallet

# --- SMTP password (SECRET — host/port/user/from are UI-editable in DCT_RPT_CONFIG) ---
$env:RPT_SMTP_PASSWORD = '<smtp-app-password>'      # Gmail/Yahoo app password for the pilot

# --- Ops alerts on report failure (optional) -----------------------------------
# $env:RPT_NOTIFY   = 'telegram'                    # telegram | webhook | (unset = off)
# $env:ATD_TG_TOKEN = '<bot-token>'
# $env:RPT_TG_CHAT  = '<chat-id>'
