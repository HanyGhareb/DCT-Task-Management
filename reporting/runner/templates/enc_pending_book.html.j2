<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ report_name }}</title>
{#- ── helpers ─────────────────────────────────────────────────────────── -#}
{%- set S = {} -%}
{%- for s in sections %}{% set _ = S.update({s.key: s}) %}{% endfor -%}
{%- set O   = (S.overview.data[0] if S.overview and S.overview.data else {}) -%}
{%- set B   = (S.budget_ctx.data[0] if S.budget_ctx and S.budget_ctx.data else {}) -%}
{%- set AG  = S.aging.data if S.aging else [] -%}
{%- set APV = S.approvers.data if S.approvers else [] -%}
{%- set SEC = S.sectors.data if S.sectors else [] -%}
{%- set OLD = S.oldest.data if S.oldest else [] -%}
{%- set PRR = S.pr_register.data if S.pr_register else [] -%}
{%- set POR = S.po_register.data if S.po_register else [] -%}
{%- set UM  = S.unmatched.data if S.unmatched else [] -%}
{#- applied report scope — mirrors the GL Encumbrances Pending Approval page filters -#}
{%- set flt = [] -%}
{%- if params.period %}{% set _ = flt.append('YTD through ' ~ params.period) %}{% endif -%}
{%- if params.sector %}{% set _ = flt.append('Sector: ' ~ params.sector) %}{% endif -%}
{%- if params.chapter %}{% set _ = flt.append('Chapter: ' ~ params.chapter) %}{% endif -%}
{%- if params.projecttype %}{% set _ = flt.append('Project type: ' ~ params.projecttype) %}{% endif -%}
{%- if params.costcenter %}{% set _ = flt.append('Cost centre: ' ~ params.costcenter) %}{% endif -%}
{%- if params.project %}{% set _ = flt.append('Project: ' ~ params.project) %}{% endif -%}
{%- if params.task %}{% set _ = flt.append('Task: ' ~ params.task) %}{% endif -%}
{%- if params.etype %}{% set _ = flt.append('Expenditure type: ' ~ params.etype) %}{% endif -%}
{%- if params.search %}{% set _ = flt.append('Search: ' ~ params.search) %}{% endif -%}
{%- set scopeline = flt|join(' · ') if flt else 'Whole organisation · Full year' -%}
{%- macro money(v) -%}
  {%- if v is none %}&mdash;
  {%- elif v|abs >= 1000000000 %}{{ (v/1000000000)|round(2)|fmt }}&nbsp;B
  {%- elif v|abs >= 1000000 %}{{ (v/1000000)|round(1)|fmt }}&nbsp;M
  {%- elif v|abs >= 1000 %}{{ (v/1000)|round(0)|int|fmt }}&nbsp;K
  {%- else %}{{ v|round(0)|int|fmt }}{%- endif -%}
{%- endmacro -%}
{%- macro dt(v) -%}{%- if v %}{{ v.strftime('%Y-%m-%d') if v.strftime is defined else v }}{% else %}&mdash;{% endif -%}{%- endmacro -%}
<style>
  :root { --brand: {{ brand|default('#1F6F8B') }}; --brand-d: #17596F; --gold: #B58900;
          --enc: #C25E10; --ok: #1E7B4D; --bad: #B3352B; --ink: #1F2933; --mut: #7B8794; }
  * { box-sizing: border-box; }
  body { font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif; color: var(--ink);
         margin: 0; font-size: 10px; }
  @page { size: A4 landscape; }
  .page { page-break-after: always; }
  .page:last-child { page-break-after: auto; }

  /* ── cover ─────────────────────────────────────────────────────────── */
  .cover { height: 172mm; position: relative; overflow: hidden;
           background: linear-gradient(135deg, #FFFFFF 55%, #F7F2EC 100%); }
  .cv-band { position: absolute; top: 0; left: 0; right: 0; height: 14mm;
             background: linear-gradient(90deg, var(--brand-d), var(--brand) 60%, #3E93AF); }
  .cv-band2 { position: absolute; bottom: 0; left: 0; right: 0; height: 6mm;
              background: linear-gradient(90deg, var(--enc), var(--gold)); }
  .cv-org { margin: 26mm 0 0 18mm; font-size: 12px; letter-spacing: .22em;
            text-transform: uppercase; color: var(--mut); }
  .cv-title { margin: 6mm 0 0 18mm; font-size: 44px; line-height: 1.08; font-weight: 800;
              color: var(--brand-d); }
  .cv-sub { margin: 4mm 0 0 18mm; font-size: 18px; color: var(--enc); font-weight: 700;
            letter-spacing: .04em; }
  .cv-scope { margin: 10mm 0 0 18mm; display: flex; gap: 8px; flex-wrap: wrap; max-width: 200mm; }
  .cv-scope span { background: #fff; border: 1px solid #E0D8CB; border-left: 4px solid var(--enc);
                   border-radius: 3px; padding: 5px 12px; font-size: 11px; color: #4E4436; }
  .cv-scope b { color: var(--brand-d); }
  .cv-desc { margin: 8mm 0 0 18mm; max-width: 150mm; font-size: 11px; line-height: 1.65;
             color: #52606D; }
  .cv-prep { position: absolute; bottom: 12mm; left: 18mm; font-size: 10.5px; color: var(--mut); }
  .cv-prep b { display: block; font-size: 13.5px; color: var(--brand-d); margin-top: 2px; }
  .cv-prep i { display: block; font-style: normal; color: #52606D; margin-top: 1px; }
  .cv-date { position: absolute; bottom: 12mm; right: 18mm; text-align: right;
             font-size: 10px; color: var(--mut); }
  .cv-date b { display: block; font-size: 12px; color: var(--ink); }

  /* ── table of contents ─────────────────────────────────────────────── */
  .toc-h { border-bottom: 3px solid var(--enc); padding-bottom: 8px; margin-bottom: 12px; }
  .toc-h h2 { margin: 0; font-size: 22px; color: var(--brand-d); }
  .toc { width: 100%; border-collapse: collapse; }
  .toc td { padding: 9px 10px; border-bottom: 1px solid #E4E7EB; vertical-align: top; }
  .toc .no { width: 52px; font-size: 17px; font-weight: 800; color: var(--enc);
             font-variant-numeric: tabular-nums; }
  .toc .t { font-size: 13px; font-weight: 700; color: var(--ink); }
  .toc .d { font-size: 10px; color: var(--mut); margin-top: 2px; }
  .toc .n { width: 150px; text-align: right; font-size: 10px; color: #52606D;
            font-variant-numeric: tabular-nums; white-space: nowrap; }

  /* ── part banner + section furniture ───────────────────────────────── */
  .pt-band { display: flex; align-items: center; gap: 12px; background:
             linear-gradient(90deg, var(--brand-d), var(--brand)); color: #fff;
             border-radius: 4px; padding: 8px 14px; margin-bottom: 10px; }
  .pt-no { font-size: 22px; font-weight: 800; opacity: .85; }
  .pt-t { font-size: 16px; font-weight: 700; }
  .pt-s { margin-left: auto; font-size: 9.5px; opacity: .85; text-align: right; }
  .sub-h { border-left: 4px solid var(--enc); background: #F8F3EC; padding: 4px 8px;
           font-size: 11.5px; font-weight: 700; color: #4A3A24; margin: 12px 0 6px; }
  .sub-h small { font-weight: 400; color: var(--mut); }

  /* ── KPI tiles ─────────────────────────────────────────────────────── */
  .kpis { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 10px; }
  .kpi { flex: 1 1 100px; border: 1px solid #D8E2E7; border-top: 3px solid var(--brand);
         border-radius: 4px; padding: 6px 9px; background: #FBFDFE; }
  .kpi.k-act { border-top-color: var(--gold); }
  .kpi.k-enc { border-top-color: var(--enc); }
  .kpi.k-ok { border-top-color: var(--ok); }
  .kpi.k-bad { border-top-color: var(--bad); }
  .k-lbl { font-size: 8px; letter-spacing: .06em; text-transform: uppercase; color: var(--mut); }
  .k-val { font-size: 15px; font-weight: 800; margin-top: 1px; font-variant-numeric: tabular-nums; }
  .k-sub { font-size: 8.5px; color: var(--mut); margin-top: 1px; }
  .neg { color: var(--bad); }

  /* ── charts (pure CSS/HTML — deterministic in print) ───────────────── */
  .charts { display: flex; gap: 14px; align-items: flex-start; }
  .chart { flex: 1 1 0; border: 1px solid #E0E8EC; border-radius: 4px; padding: 8px 10px;
           background: #fff; }
  .ch-t { font-size: 10px; font-weight: 700; color: #24404B; margin-bottom: 6px; }
  .hb-row { display: flex; align-items: center; gap: 6px; margin: 3px 0; }
  .hb-lbl { flex: 0 0 130px; font-size: 8.5px; color: #3E4C59; text-align: right;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .hb-track { flex: 1 1 0; background: #EEF2F5; border-radius: 2px; height: 9px; }
  .hb-bar { height: 9px; border-radius: 2px; background: var(--brand); min-width: 1px; }
  .hb-bar.warn { background: var(--enc); } .hb-bar.bad { background: var(--bad); }
  .hb-bar.gold { background: var(--gold); } .hb-bar.ok { background: var(--ok); }
  .hb-val { flex: 0 0 84px; font-size: 8.5px; color: #33525E; font-variant-numeric: tabular-nums;
            white-space: nowrap; }
  .stack { display: flex; height: 20px; border-radius: 3px; overflow: hidden; margin: 4px 0 6px; }
  .stack div { height: 20px; }
  .lg { display: flex; gap: 12px; flex-wrap: wrap; font-size: 8.5px; color: #3E4C59; }
  .lg i { display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 4px; }

  /* ── data tables ───────────────────────────────────────────────────── */
  table.data { border-collapse: collapse; width: 100%; }
  table.data thead th { background: var(--brand); color: #fff; font-weight: 600; text-align: left;
                        padding: 4px 6px; font-size: 8.5px; border: 1px solid var(--brand-d); }
  table.data tbody td { padding: 3px 6px; border: 1px solid #E4E7EB; vertical-align: top;
                        font-size: 8.5px; }
  table.data tbody tr:nth-child(even) td { background: #F5F7FA; }
  td.num, tfoot td.num { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  table.data tfoot td { padding: 4px 6px; border: 1px solid #CBD2D9; background: #E3ECEF;
                        font-weight: 700; color: #24404B; font-size: 8.5px; }
  .empty { padding: 16px; text-align: center; color: var(--mut); font-style: italic;
           border: 1px dashed #D3DCE2; }
  .pill { display: inline-block; border-radius: 8px; padding: 0 6px; font-size: 8px; }
  .pill.res { background: #E1F3E8; color: var(--ok); }
  .pill.unres { background: #FBE4E1; color: var(--bad); }
  .pill.aged { background: #FCE9DB; color: var(--enc); }

  /* ── insights ──────────────────────────────────────────────────────── */
  .ins { border: 1px solid #E0E8EC; border-left: 4px solid var(--enc); border-radius: 4px;
         background: #FDFCFA; padding: 9px 12px; margin-bottom: 8px; }
  .ins .i-t { font-size: 11px; font-weight: 700; color: var(--brand-d); margin-bottom: 2px; }
  .ins .i-b { font-size: 10px; line-height: 1.55; color: #3E4C59; }
  .ins b { color: var(--ink); }
  .i-good { color: var(--ok) !important; font-weight: 700; }
  .i-bad { color: var(--bad) !important; font-weight: 700; }
  .meth { margin-top: 12px; border: 1px dashed #C9D6DC; border-radius: 4px; padding: 9px 12px;
          background: #F7FAFB; }
  .meth h4 { margin: 0 0 5px; font-size: 10px; color: var(--brand-d); text-transform: uppercase;
             letter-spacing: .08em; }
  .meth div { font-size: 9px; color: #52606D; line-height: 1.6; }
  .meth b { color: #33525E; }
  .foot { margin-top: 10px; font-size: 8px; color: #9AA5B1; text-align: center; }
</style>
</head>
<body>

{#- ═══ COVER ═══════════════════════════════════════════════════════════ -#}
<div class="page cover">
  <div class="cv-band"></div>
  <div class="cv-org">i-Finance &middot; Reporting Platform</div>
  <div class="cv-title">Encumbrances Pending Approval<br>Briefing Book</div>
  <div class="cv-sub">Budget Year {{ params.year }}{% if params.period %} &mdash; YTD through {{ params.period }}{% endif %}</div>
  <div class="cv-scope">
    <span>Scope <b>{{ params.sector if params.sector else 'All sectors' }}</b></span>
    {% if params.period %}<span>Period <b>YTD {{ params.period }}</b></span>{% endif %}
    {% if params.chapter %}<span>Chapter <b>{{ params.chapter }}</b></span>{% endif %}
    {% if params.projecttype %}<span>Project type <b>{{ params.projecttype }}</b></span>{% endif %}
    {% if params.costcenter %}<span>Cost centre <b>{{ params.costcenter }}</b></span>{% endif %}
    {% if params.project %}<span>Project <b>{{ params.project }}</b></span>{% endif %}
    {% if params.task %}<span>Task <b>{{ params.task }}</b></span>{% endif %}
    {% if params.etype %}<span>Expenditure type <b>{{ params.etype }}</b></span>{% endif %}
    {% if params.search %}<span>Search <b>{{ params.search }}</b></span>{% endif %}
    <span>Pending documents <b>{{ O.docs|fmt if O.docs is not none else '—' }}</b></span>
    <span>Pending value <b>{{ money(O.amt_total) }} AED</b></span>
    <span>Avg wait <b>{{ O.avg_days|fmt }} days</b></span>
    <span>Basis <b>Reserved, non-zero lines</b></span>
  </div>
  <div class="cv-desc">
    This briefing book presents every funds-reserved purchase requisition and purchase order awaiting
    approval in Oracle Fusion for budget year {{ params.year }}{% if params.period %} (year-to-date
    through {{ params.period }}){% endif %}, covering
    {{ 'the ' + params.sector + ' sector' if params.sector else 'all sectors' }}
    {%- if params.chapter %}, chapter &ldquo;{{ params.chapter }}&rdquo;{% endif %}
    {%- if params.projecttype %}, {{ params.projecttype }} projects{% endif %}: a monitoring overview
    with aging and sector analysis, the approver follow-up list with the longest-waiting documents,
    the full pending requisition and purchase-order registers with their budget lines, and closing
    observations for management review. All amounts are in AED. The scope matches the GL
    &ldquo;Encumbrances &ndash; Pending Approval&rdquo; page filters the report was launched with.
  </div>
  <div class="cv-prep">Prepared by
    <b>Financial Planning and Budgeting</b>
    <i>Finance Department</i>
  </div>
  <div class="cv-date">Generated<b>{{ generated_at }} GST (UTC+04:00)</b>Asia/Dubai &middot; {{ report_code }}</div>
  <div class="cv-band2"></div>
</div>

{#- ═══ INDEX ═══════════════════════════════════════════════════════════ -#}
<div class="page">
  <div class="toc-h"><h2>Contents</h2></div>
  <table class="toc">
    <tr><td class="no">01</td>
        <td><div class="t">Pending Approval Overview</div>
            <div class="d">How much demand is waiting in the approval queue, how it splits between requisitions and purchase orders, how long it has been waiting, and where it lands on the budget.</div></td>
        <td class="n">{{ O.docs|fmt }} documents &middot; {{ money(O.amt_total) }} AED</td></tr>
    <tr><td class="no">02</td>
        <td><div class="t">Approver Follow-up</div>
            <div class="d">Who is holding the queue: pending value and document count per approver, and the twenty longest-waiting documents.</div></td>
        <td class="n">{{ APV|length }} approvers &middot; oldest {{ O.max_days|fmt }} days</td></tr>
    <tr><td class="no">03</td>
        <td><div class="t">Pending Purchase Requisitions</div>
            <div class="d">The full register of requisition lines awaiting approval, with budget line, submitted date, days pending and the current approver.</div></td>
        <td class="n">{{ PRR|length|fmt }} PR lines &middot; {{ money(O.amt_pr) }} AED</td></tr>
    <tr><td class="no">04</td>
        <td><div class="t">Pending Purchase Orders</div>
            <div class="d">The full register of purchase-order lines awaiting approval, with the GRN-netted open amount per line.</div></td>
        <td class="n">{{ POR|length|fmt }} PO lines &middot; {{ money(O.amt_po) }} AED</td></tr>
    <tr><td class="no">05</td>
        <td><div class="t">Observations &amp; Insights</div>
            <div class="d">What the queue says: aging pressure, approval bottlenecks, the budget impact of approval, and the methodology behind every figure — with the extract-coverage annex.</div></td>
        <td class="n">{{ UM|length|fmt }} unmatched documents</td></tr>
  </table>
  <div class="foot">{{ meta }} &middot; times in GST (UTC+04:00, Asia/Dubai)</div>
</div>

{#- ═══ PART 1 — OVERVIEW ═══════════════════════════════════════════════ -#}
<div class="page">
  <div class="pt-band"><span class="pt-no">01</span><span class="pt-t">Pending Approval Overview</span>
    <span class="pt-s">Budget year {{ params.year }} &middot; {{ scopeline|truncate(80) }}</span></div>

  <div class="kpis">
    <div class="kpi"><div class="k-lbl">Pending Documents</div><div class="k-val">{{ O.docs|fmt }}</div><div class="k-sub">{{ O.lines|fmt }} budget lines</div></div>
    <div class="kpi"><div class="k-lbl">Requisitions (PR)</div><div class="k-val">{{ O.pr_docs|fmt }}</div><div class="k-sub">{{ money(O.amt_pr) }} AED</div></div>
    <div class="kpi"><div class="k-lbl">Purchase Orders (PO)</div><div class="k-val">{{ O.po_docs|fmt }}</div><div class="k-sub">{{ money(O.amt_po) }} AED</div></div>
    <div class="kpi k-enc"><div class="k-lbl">Pending Value</div><div class="k-val">{{ money(O.amt_total) }}</div><div class="k-sub">AED awaiting approval &middot; reserved lines</div></div>
    <div class="kpi k-ok"><div class="k-lbl">In Open Encumbrance</div><div class="k-val">{{ money(O.enc_open_aed) }}</div><div class="k-sub">open amount already counted (PO GRN-netted)</div></div>
    <div class="kpi k-act"><div class="k-lbl">Average Wait</div><div class="k-val">{{ O.avg_days|fmt }}</div><div class="k-sub">days pending &middot; oldest {{ O.max_days|fmt }}</div></div>
    <div class="kpi {{ 'k-bad' if O.over30_docs else 'k-ok' }}"><div class="k-lbl">Over 30 Days</div><div class="k-val {{ 'neg' if O.over30_docs }}">{{ O.over30_docs|fmt }}</div><div class="k-sub">documents &middot; {{ money(O.over30_amt) }} AED</div></div>
  </div>

  <div class="charts">
    <div class="chart" style="flex: 1.2 1 0">
      <div class="ch-t">Pending value composition — {{ money(O.amt_total) }} AED awaiting approval</div>
      {% set T = O.amt_total or 0 %}
      {% if T > 0 %}
      {% set w_pr = (100 * (O.amt_pr or 0) / T)|round(2) %}
      {% set w_po = 100 - w_pr %}
      <div class="stack">
        <div style="width:{{ [w_pr,0]|max }}%; background: var(--brand);"></div>
        <div style="width:{{ [w_po,0]|max }}%; background: var(--enc);"></div>
      </div>
      <div class="lg">
        <span><i style="background:var(--brand)"></i>Requisitions {{ w_pr }}%</span>
        <span><i style="background:var(--enc)"></i>Purchase orders {{ w_po|round(2) }}%</span>
      </div>
      {% else %}<div class="empty">No pending value in scope.</div>{% endif %}

      <div class="ch-t" style="margin-top:12px">Where the pending demand lands — budget frame (AED)</div>
      {% set bmax = [(B.budget or 0), (B.open_encumbrance or 0), (B.fund_available or 0)|abs, (O.amt_total or 0)]|max %}
      {% if bmax %}
      <div class="hb-row"><div class="hb-lbl">Approved budget</div>
        <div class="hb-track"><div class="hb-bar" style="width:{{ (100*(B.budget or 0)/bmax)|round(1) }}%"></div></div>
        <div class="hb-val">{{ money(B.budget) }}</div></div>
      <div class="hb-row"><div class="hb-lbl">Open encumbrance (PR+PO)</div>
        <div class="hb-track"><div class="hb-bar warn" style="width:{{ (100*(B.open_encumbrance or 0)/bmax)|round(1) }}%"></div></div>
        <div class="hb-val">{{ money(B.open_encumbrance) }}</div></div>
      <div class="hb-row"><div class="hb-lbl">&hellip;of which pending approval</div>
        <div class="hb-track"><div class="hb-bar gold" style="width:{{ (100*(O.enc_open_aed or 0)/bmax)|round(1) }}%"></div></div>
        <div class="hb-val">{{ money(O.enc_open_aed) }}</div></div>
      <div class="hb-row"><div class="hb-lbl">Fund available</div>
        <div class="hb-track"><div class="hb-bar {{ 'bad' if B.fund_available is not none and B.fund_available < 0 else 'ok' }}" style="width:{{ (100*((B.fund_available or 0)|abs)/bmax)|round(1) }}%"></div></div>
        <div class="hb-val">{{ money(B.fund_available) }}</div></div>
      {% else %}<div class="empty">No budget frame in scope.</div>{% endif %}
    </div>
    <div class="chart">
      <div class="ch-t">Aging — pending value and documents by days waiting</div>
      {% set agmax = (AG|map(attribute='amount_aed')|select('number')|max) if AG else 0 %}
      {% for r in AG %}
      <div class="hb-row"><div class="hb-lbl">{{ r.bucket }} days</div>
        <div class="hb-track"><div class="hb-bar {{ 'bad' if r.bucket == '31+' else 'warn' if r.bucket == '16-30' else '' }}"
             style="width:{{ (100*(r.amount_aed or 0)/agmax)|round(1) if agmax else 0 }}%"></div></div>
        <div class="hb-val">{{ money(r.amount_aed) }} &middot; {{ r.docs|fmt }} docs</div></div>
      {% endfor %}
      {% if not AG %}<div class="empty">No aging data.</div>{% endif %}

      <div class="ch-t" style="margin-top:12px">Top pending approvers by value held</div>
      {% set apmax = (APV|map(attribute='amount_aed')|select('number')|max) if APV else 0 %}
      {% for r in APV[:10] %}
      <div class="hb-row"><div class="hb-lbl">{{ (r.pending_with or '(Unassigned)')|string|truncate(26) }}</div>
        <div class="hb-track"><div class="hb-bar {{ 'bad' if r.max_days and r.max_days > 30 else 'warn' }}"
             style="width:{{ (100*(r.amount_aed or 0)/apmax)|round(1) if apmax else 0 }}%"></div></div>
        <div class="hb-val">{{ money(r.amount_aed) }} &middot; {{ r.docs|fmt }} docs</div></div>
      {% endfor %}
      {% if not APV %}<div class="empty">No approver data.</div>{% endif %}
    </div>
  </div>
  <div class="foot">Part 1 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

<div class="page">
  <div class="sub-h">1.1 &nbsp; Aging analysis <small>&mdash; days pending approval, document grain, all figures AED</small></div>
  {% if AG %}
  <table class="data">
    <thead><tr><th>Days Pending</th><th>Documents</th><th>Requisitions</th><th>Purchase Orders</th><th>Pending Amount (AED)</th><th>Share of Pending Value</th></tr></thead>
    <tbody>
      {% for r in AG %}
      <tr><td>{{ r.bucket }}</td><td class="num">{{ r.docs|fmt }}</td>
        <td class="num">{{ r.pr_docs|fmt }}</td><td class="num">{{ r.po_docs|fmt }}</td>
        <td class="num">{{ r.amount_aed|fmt }}</td>
        <td class="num">{{ (100*(r.amount_aed or 0)/O.amt_total)|round(1) if O.amt_total else '—' }}%</td></tr>
      {% endfor %}
    </tbody>
    <tfoot><tr><td>Total</td><td class="num">{{ O.docs|fmt }}</td>
      <td class="num">{{ O.pr_docs|fmt }}</td><td class="num">{{ O.po_docs|fmt }}</td>
      <td class="num">{{ O.amt_total|fmt }}</td><td class="num">100%</td></tr></tfoot>
  </table>
  {% else %}<div class="empty">No documents pending approval for the selected criteria.</div>{% endif %}

  <div class="sub-h">1.2 &nbsp; Pending value by sector <small>&mdash; via the canonical GL combination of each line</small></div>
  {% if SEC %}
  <table class="data">
    <thead><tr><th>Sector</th><th>Documents</th><th>Lines</th><th>Pending Amount (AED)</th><th>Of Which Over 30 Days</th><th>Share</th></tr></thead>
    <tbody>
      {% for r in SEC %}
      <tr><td>{{ r.sector }}</td><td class="num">{{ r.docs|fmt }}</td><td class="num">{{ r.lines|fmt }}</td>
        <td class="num">{{ r.amount_aed|fmt }}</td>
        <td class="num {{ 'neg' if r.over30_aed and r.over30_aed > 0.005 }}">{{ r.over30_aed|fmt }}</td>
        <td class="num">{{ (100*(r.amount_aed or 0)/O.amt_total)|round(1) if O.amt_total else '—' }}%</td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}<div class="empty">No sector data for the selected criteria.</div>{% endif %}
  <div class="foot">Part 1 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

{#- ═══ PART 2 — APPROVER FOLLOW-UP ═════════════════════════════════════ -#}
<div class="page">
  <div class="pt-band"><span class="pt-no">02</span><span class="pt-t">Approver Follow-up</span>
    <span class="pt-s">{{ APV|length }} approvers holding {{ money(O.amt_total) }} AED</span></div>

  <div class="sub-h">2.1 &nbsp; Pending value per approver <small>&mdash; top {{ APV|length }} by amount held; chase the top of this list first</small></div>
  {% if APV %}
  <table class="data">
    <thead><tr><th>Pending With</th><th>Documents</th><th>Lines</th><th>Amount Held (AED)</th><th>Share</th><th>Longest Wait (days)</th><th>Oldest Submission</th></tr></thead>
    <tbody>
      {% for r in APV %}
      <tr><td>{{ r.pending_with or '(Unassigned)' }}</td>
        <td class="num">{{ r.docs|fmt }}</td><td class="num">{{ r.lines|fmt }}</td>
        <td class="num">{{ r.amount_aed|fmt }}</td>
        <td class="num">{{ (100*(r.amount_aed or 0)/O.amt_total)|round(1) if O.amt_total else '—' }}%</td>
        <td class="num {{ 'neg' if r.max_days and r.max_days > 30 }}">{{ r.max_days|fmt }}</td>
        <td class="num">{{ dt(r.oldest_submitted) }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}<div class="empty">No documents pending approval for the selected criteria.</div>{% endif %}

  <div class="sub-h">2.2 &nbsp; The twenty longest-waiting documents <small>&mdash; document grain, oldest first</small></div>
  {% if OLD %}
  <table class="data">
    <thead><tr><th>Type</th><th>Document #</th><th>Description / Supplier</th><th>Preparer / Buyer</th><th>Submitted</th><th>Days Pending</th><th>Pending With</th><th>Sector</th><th>Cost Centre</th><th>Appropriation</th><th>Amount (AED)</th></tr></thead>
    <tbody>
      {% for r in OLD %}
      <tr><td>{{ r.source }}</td><td>{{ r.doc_number }}</td>
        <td>{{ r.description or '—' }}</td>
        <td>{{ r.preparer_buyer or '—' }}</td>
        <td class="num">{{ dt(r.submitted_date) }}</td>
        <td class="num {{ 'neg' if r.pending_days and r.pending_days > 30 }}">{{ r.pending_days|fmt }}</td>
        <td>{{ r.pending_with or '—' }}</td>
        <td>{{ r.sector or '—' }}</td>
        <td>{{ r.cost_centre or '—' }}</td>
        <td>{{ r.appropriation or '—' }}</td>
        <td class="num">{{ r.doc_amt|fmt }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}<div class="empty">No documents pending approval for the selected criteria.</div>{% endif %}
  <div class="foot">Part 2 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

{#- ═══ PART 3 — PENDING PR REGISTER ════════════════════════════════════ -#}
<div class="page">
  <div class="pt-band"><span class="pt-no">03</span><span class="pt-t">Pending Purchase Requisitions</span>
    <span class="pt-s">{{ PRR|length|fmt }} lines &middot; {{ money(O.amt_pr) }} AED</span></div>
  <div class="sub-h">3.1 &nbsp; Requisition lines awaiting approval <small>&mdash; funds-reserved lines, oldest first; all figures AED</small></div>
  {% if PRR %}
  <table class="data">
    <thead><tr><th>PR #</th><th>Line</th><th>Description</th><th>Preparer</th><th>Submitted</th><th>Days</th><th>Pending With</th>
      <th>Project</th><th>Task</th><th>Expenditure Type</th><th>Sector</th><th>Cost Centre</th><th>Appropriation</th><th>Budget Date</th><th>Amount (AED)</th></tr></thead>
    <tbody>
      {% for r in PRR %}
      <tr><td>{{ r.doc_number }}</td><td class="num">{{ r.doc_line }}</td>
        <td>{{ r.description or '—' }}</td>
        <td>{{ r.preparer_buyer or '—' }}</td>
        <td class="num">{{ dt(r.submitted_date) }}</td>
        <td class="num {{ 'neg' if r.pending_days and r.pending_days > 30 }}">{{ r.pending_days|fmt }}</td>
        <td>{{ r.pending_with or '—' }}</td>
        <td>{{ r.project_number }} {{ r.project_name or '' }}</td>
        <td>{{ r.task_number or '—' }}</td><td>{{ r.expenditure_type or '—' }}</td>
        <td>{{ r.sector_name or '—' }}</td>
        <td>{% if r.cost_center_code %}{{ r.cost_center_code }} - {{ r.cost_center_desc or '' }}{% else %}&mdash;{% endif %}</td>
        <td>{% if r.appropriation_code %}{{ r.appropriation_code }} - {{ r.appropriation_desc or '' }}{% else %}&mdash;{% endif %}</td>
        <td class="num">{{ dt(r.budget_date) }}</td>
        <td class="num">{{ r.line_aed|fmt }}</td></tr>
      {% endfor %}
    </tbody>
    <tfoot><tr><td colspan="14">Total — {{ PRR|length|fmt }} requisition lines</td>
      <td class="num">{{ O.amt_pr|fmt }}</td></tr></tfoot>
  </table>
  {% else %}<div class="empty">No requisitions pending approval for the selected criteria.</div>{% endif %}
  <div class="foot">Part 3 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

{#- ═══ PART 4 — PENDING PO REGISTER ════════════════════════════════════ -#}
<div class="page">
  <div class="pt-band"><span class="pt-no">04</span><span class="pt-t">Pending Purchase Orders</span>
    <span class="pt-s">{{ POR|length|fmt }} lines &middot; {{ money(O.amt_po) }} AED</span></div>
  <div class="sub-h">4.1 &nbsp; Purchase-order lines awaiting approval <small>&mdash; funds-reserved lines, oldest first; open = GRN-netted; all figures AED</small></div>
  {% if POR %}
  <table class="data">
    <thead><tr><th>PO #</th><th>Line</th><th>Supplier</th><th>Buyer</th><th>Submitted</th><th>Days</th><th>Pending With</th>
      <th>Project</th><th>Task</th><th>Expenditure Type</th><th>Sector</th><th>Cost Centre</th><th>Appropriation</th><th>Budget Date</th><th>Line (AED)</th><th>Open (AED)</th></tr></thead>
    <tbody>
      {% for r in POR %}
      <tr><td>{{ r.doc_number }}</td><td class="num">{{ r.doc_line }}</td>
        <td>{{ r.supplier_name or '—' }}</td>
        <td>{{ r.preparer_buyer or '—' }}</td>
        <td class="num">{{ dt(r.submitted_date) }}</td>
        <td class="num {{ 'neg' if r.pending_days and r.pending_days > 30 }}">{{ r.pending_days|fmt }}</td>
        <td>{{ r.pending_with or '—' }}</td>
        <td>{{ r.project_number }} {{ r.project_name or '' }}</td>
        <td>{{ r.task_number or '—' }}</td><td>{{ r.expenditure_type or '—' }}</td>
        <td>{{ r.sector_name or '—' }}</td>
        <td>{% if r.cost_center_code %}{{ r.cost_center_code }} - {{ r.cost_center_desc or '' }}{% else %}&mdash;{% endif %}</td>
        <td>{% if r.appropriation_code %}{{ r.appropriation_code }} - {{ r.appropriation_desc or '' }}{% else %}&mdash;{% endif %}</td>
        <td class="num">{{ dt(r.budget_date) }}</td>
        <td class="num">{{ r.line_aed|fmt }}</td><td class="num">{{ r.open_aed|fmt }}</td></tr>
      {% endfor %}
    </tbody>
    <tfoot><tr><td colspan="14">Total — {{ POR|length|fmt }} purchase-order lines</td>
      <td class="num">{{ O.amt_po|fmt }}</td><td class="num"></td></tr></tfoot>
  </table>
  {% else %}<div class="empty">No purchase orders pending approval for the selected criteria.</div>{% endif %}
  <div class="foot">Part 4 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

{#- ═══ PART 5 — INSIGHTS ═══════════════════════════════════════════════ -#}
{%- set T = O.amt_total or 0 -%}
{%- set over30_share = (100 * (O.over30_amt or 0) / T)|round(1) if T else 0 -%}
{%- set top_apv = APV[0] if APV else none -%}
{%- set top_share = (100 * (top_apv.amount_aed or 0) / T)|round(1) if top_apv and T else 0 -%}
{%- set enc_share = (100 * (O.enc_open_aed or 0) / B.open_encumbrance)|round(1) if B.open_encumbrance else 0 -%}
<div class="page">
  <div class="pt-band"><span class="pt-no">05</span><span class="pt-t">Observations &amp; Insights</span>
    <span class="pt-s">prepared for management review &middot; {{ params.year }}</span></div>

  <div class="ins"><div class="i-t">Approval velocity</div><div class="i-b">
    {{ O.docs|fmt }} documents worth <b>{{ money(T) }} AED</b> are waiting in the approval queue, at an average of
    <b>{{ O.avg_days|fmt }} days</b> pending (oldest: {{ O.max_days|fmt }} days).
    {% if O.over30_docs %}<span class="i-bad">{{ O.over30_docs|fmt }} documents ({{ money(O.over30_amt) }} AED — {{ over30_share }}% of the pending value) have been waiting more than 30 days</span> — these are stalled, not merely in transit, and should be escalated first.{% else %}<span class="i-good">No document has been waiting more than 30 days</span> — the queue is turning over at a healthy pace.{% endif %}
  </div></div>

  {% if top_apv %}
  <div class="ins"><div class="i-t">Where the queue is held</div><div class="i-b">
    <b>{{ (top_apv.pending_with or '(Unassigned)')|string|truncate(60) }}</b> currently holds the largest share:
    {{ top_apv.docs|fmt }} documents worth <b>{{ money(top_apv.amount_aed) }} AED</b>
    ({{ top_share }}% of the pending value), the longest waiting {{ top_apv.max_days|fmt }} days.
    {% if top_share > 30 %}<span class="i-bad">This is a concentration risk</span> — a single approver gates nearly a third or more of the queue; consider delegation or vacation rules.{% else %}The remainder is spread across {{ (APV|length - 1)|fmt }} other approvers (see Part 2 for the full follow-up list).{% endif %}
  </div></div>
  {% endif %}

  <div class="ins"><div class="i-t">Budget impact of approval</div><div class="i-b">
    Every document in this book is already funds-<b>Reserved</b> (the report covers reserved, non-zero lines only),
    so its value sits INSIDE the open-encumbrance figures on the Budget Utilization page:
    <b>{{ money(O.enc_open_aed) }} AED</b> of open amount — {{ enc_share }}% of the
    {{ money(B.open_encumbrance) }} AED open encumbrance in this scope. <span class="i-good">Approving these
    documents changes workflow state, not the budget position</span>; fund available
    ({{ money(B.fund_available) }} AED) is unaffected by the approvals themselves.
  </div></div>

  <div class="ins"><div class="i-t">Composition of the queue</div><div class="i-b">
    Requisitions dominate by value: <b>{{ money(O.amt_pr) }} AED</b> across {{ O.pr_docs|fmt }} PRs versus
    <b>{{ money(O.amt_po) }} AED</b> across {{ O.po_docs|fmt }} POs.
    {% if SEC %}By sector, <b>{{ SEC[0].sector }}</b> carries the largest pending value
    ({{ money(SEC[0].amount_aed) }} AED — {{ (100*(SEC[0].amount_aed or 0)/T)|round(1) if T else 0 }}%).{% endif %}
    Pending requisitions are demand that will convert into purchase orders — a long PR queue today is next
    month's obligation pipeline.
  </div></div>

  {% if UM %}
  <div class="ins"><div class="i-t">Extract coverage</div><div class="i-b">
    <b>{{ UM|length|fmt }} pending documents</b> from the Fusion snapshot could not be matched to a project budget line
    in the analytics extract (extract timing, or non-project documents). They are excluded from every figure above
    but are listed in full in the <b>Annex</b> so nothing pending is silently dropped.
  </div></div>
  {% endif %}

  <div class="meth">
    <h4>How the figures are defined</h4>
    <div>
      <b>Source.</b> The pending queue is the daily Fusion BI Publisher snapshot &ldquo;ADG Document Status Report&rdquo;
      (documents with status PENDING APPROVAL), refreshed each morning and joined to the PR / PO distribution detail
      of the analytics extract. &nbsp;<b>Scope.</b> Identical to the GL Budget Utilization page: budget year on the
      distribution budget date, the same sector / chapter / project-type / cost-centre / project / task /
      expenditure-type / search predicates{% if params.period %}, and the YTD window through {{ params.period }}{% endif %}.
      &nbsp;<b>Amounts.</b> AED; PR lines convert via the platform currency snapshot, PO lines via the distribution rate.
      &nbsp;<b>Scope rule.</b> Funds-RESERVED, non-zero lines only: not-reserved documents and zero-value lines are
      excluded from every figure and register in this book (business rule, 2026-07-16); the GL page still shows them.
      &nbsp;<b>In encumbrance.</b> Reserved (PR) / Reserved-Partially Liquidated with GRN netting (PO) — the same
      bases as the page's Open Commitment and Open Obligation figures. &nbsp;<b>Sector / Cost centre / Appropriation.</b>
      Resolved from each line's canonical GL combination; document-grain rows show &ldquo;(Multiple)&rdquo; when a
      document spans several combinations. &nbsp;<b>Days pending.</b> As reported by Fusion (workflow submission to
      snapshot time), measured per document; document amounts sum that document's budget lines.
    </div>
  </div>
  <div class="foot">Part 5 &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }} &middot; Amounts in AED</div>
</div>

{#- ═══ ANNEX — UNMATCHED DOCUMENTS ═════════════════════════════════════ -#}
{% if UM %}
<div class="page">
  <div class="pt-band"><span class="pt-no">A</span><span class="pt-t">Annex — Documents Not in the Budget Extract</span>
    <span class="pt-s">{{ UM|length|fmt }} documents &middot; whole snapshot (not limited by the page filters)</span></div>
  <div class="sub-h">A.1 &nbsp; Pending documents without a matched project budget line <small>&mdash; extract timing or non-project documents; oldest first</small></div>
  <table class="data">
    <thead><tr><th>Type</th><th>Business Unit</th><th>Document #</th><th>Preparer / Buyer</th><th>Submitted</th><th>Days Pending</th><th>Pending With</th></tr></thead>
    <tbody>
      {% for r in UM %}
      <tr><td>{{ r.source }}</td><td>{{ r.business_unit or '—' }}</td>
        <td>{{ r.doc_number }}</td>
        <td>{{ r.preparer_buyer or '—' }}</td>
        <td class="num">{{ dt(r.submitted_date) }}</td>
        <td class="num {{ 'neg' if r.pending_days and r.pending_days > 30 }}">{{ r.pending_days|fmt }}</td>
        <td>{{ r.pending_with or '—' }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  <div class="foot">Annex &middot; Encumbrances Pending Approval Briefing Book &middot; {{ params.year }}</div>
</div>
{% endif %}

</body>
</html>
