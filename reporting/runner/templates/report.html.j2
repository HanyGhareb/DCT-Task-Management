<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ report_name }}</title>
<style>
  :root { --brand: {{ brand|default('#1F6F8B') }}; }
  * { box-sizing: border-box; }
  body { font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif; color: #1f2933;
         margin: 0; font-size: 11px; }
  .head { border-bottom: 3px solid var(--brand); padding: 0 0 10px; margin-bottom: 14px; }
  .brandrow { display: flex; align-items: baseline; justify-content: space-between; }
  .title { font-size: 20px; font-weight: 700; color: var(--brand); margin: 0; }
  .org { font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: #7b8794; }
  .meta { margin-top: 4px; font-size: 10px; color: #52606d; }
  table { border-collapse: collapse; width: 100%; }
  thead th { background: var(--brand); color: #fff; font-weight: 600; text-align: left;
             padding: 7px 8px; font-size: 10px; border: 1px solid var(--brand); }
  tbody td { padding: 5px 8px; border: 1px solid #e4e7eb; vertical-align: top; }
  tbody tr:nth-child(even) td { background: #f5f7fa; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  .empty { padding: 24px; text-align: center; color: #7b8794; font-style: italic; }
  .foot { margin-top: 12px; font-size: 9px; color: #9aa5b1; text-align: center; }
  @page { size: A4; }
</style>
</head>
<body>
  <div class="head">
    <div class="brandrow">
      <h1 class="title">{{ report_name }}</h1>
      <div class="org">i-Finance · Reporting</div>
    </div>
    <div class="meta">{{ meta }}</div>
  </div>

  {% if rows and rows|length > 0 %}
  <table>
    <thead>
      <tr>{% for h in headers %}<th>{{ h }}</th>{% endfor %}</tr>
    </thead>
    <tbody>
      {% for row in rows %}
      <tr>{% for cell in row %}<td class="{{ 'num' if cell is num else '' }}">{{ cell|fmt }}</td>{% endfor %}</tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="empty">No data for the selected criteria.</div>
  {% endif %}

  <div class="foot">Generated {{ generated_at }} (Asia/Dubai) · {{ report_code }}</div>
</body>
</html>
