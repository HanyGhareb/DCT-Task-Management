# otbi-atd worker env (Linux). Copy to a secrets store, fill in, deploy as ~/otbi-atd/env.sh
# (chmod 600). IDENTICAL on every VM — worker id defaults to the hostname, so nothing per-VM.
# Keep the real file OUT of git.
export OTBI_USER='<fusion-user>@dctabudhabi.ae'
export OTBI_PWD='<fusion-password>'
export ATD_STATE_DIR="$HOME/otbi-atd-state"     # saved Fusion session + mfa file
export ATD_MFA_WAIT="600"                        # seconds to wait for the MFA approval

# Telegram MFA + alerts
export ATD_NOTIFY="telegram"
export ATD_TG_TOKEN="<bot token>"
export ATD_TG_CHAT="<chat id>"

# Fast oracledb thin-mode load (uses the wallet in TNS_ADMIN)
export ATD_DB_MODE="oracledb"
export ATD_DB_USER="ADMIN"
export ATD_DB_PASSWORD="<db password>"
export ATD_WALLET_PASSWORD="<wallet password (= db password)>"
export ATD_DB_DSN="prod_low"
export TNS_ADMIN="$HOME/wallet"                  # ewallet.pem + tnsnames.ora live here
export ATD_DB_CHUNK="5000"
export ATD_LEASE_MINUTES="10"                    # crash-recovery lease for the shared queue
